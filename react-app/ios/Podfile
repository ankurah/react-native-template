# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target '{{project-name | pascal_case}}' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # UniFFI native module
  pod '{{project-name | pascal_case}}', :path => '..'

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # fmt 11.0.2 (pinned by React Native 0.83) turns on consteval format-string
    # checking whenever the compiler advertises __cpp_consteval, but Xcode 26's
    # clang rejects those consteval calls ("call to consteval function ... is not
    # a constant expression"), breaking the fmt/folly build. A -D override can't
    # win because base.h (re)defines FMT_USE_CONSTEVAL unconditionally, so force
    # the header onto its (fully supported) runtime path instead. Self-healing:
    # re-applied on every `pod install`.
    fmt_base = File.join(installer.sandbox.root, 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base)
      text = File.read(fmt_base)
      patched = text.gsub('#  define FMT_USE_CONSTEVAL 1', '#  define FMT_USE_CONSTEVAL 0')
      if patched != text
        File.write(fmt_base, patched)
        Pod::UI.puts "Patched fmt/base.h to disable consteval (Xcode 26 compatibility)".green
      end
    end
  end
end
